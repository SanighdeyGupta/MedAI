# MedAI environment variables.
# Copy to .env.local and fill in. The app will fall back to JSON seed data
# if these are unset, so you can develop without Supabase configured.

# --- Supabase (Day 2) ---
# Get these from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — server-side only. Used by scripts/seed.ts and (later) the
# on-demand refresh route. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# --- ScraperAPI (Day 6, on-demand 1mg fetches) ---
# Get from https://www.scraperapi.com/ free tier
SCRAPERAPI_KEY=
